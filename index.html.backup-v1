  <!-- Article Category Filter -->
  <script>
  (function(){
    function filterArticles() {
      var h = window.location.hash;
      var cards = document.querySelectorAll('.article-card');
      if (h.indexOf('#articles-') === 0) {
        var cat = h.replace('#articles-', '');
        for (var i = 0; i < cards.length; i++) {
          var tagEl = cards[i].querySelector('.article-tag');
          var tagText = tagEl ? tagEl.textContent.trim().toLowerCase().replace(/\s+/g, '-') : '';
          cards[i].style.display = (tagText === cat) ? '' : 'none';
        }
        var sec = document.getElementById('articles');
        if (sec) sec.scrollIntoView({behavior: 'smooth'});
      } else {
        for (var j = 0; j < cards.length; j++) {
          cards[j].style.display = '';
        }
      }
    }
    filterArticles();
    window.addEventListener('hashchange', filterArticles);
  })();
  </script>

